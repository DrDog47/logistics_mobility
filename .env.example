# Copy this file to `.env` and fill in the real values. `.env` is git-ignored
# and must never be committed.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Local dev database (Postgres via docker compose, exposed on localhost:5432)
DATABASE_URL=postgresql+psycopg://mobility:mobility@localhost:5432/mobility

# Credentials for the docker compose `db` service
POSTGRES_DB=mobility
POSTGRES_USER=mobility
POSTGRES_PASSWORD=mobility

# Where uploaded document files are stored (defaults to ./documents if unset)
# DOCUMENTS_DIR=/app/documents

# Document recognizer: "claude" (live API) or "fake" (offline/dev/tests)
DOCUMENT_RECOGNIZER=claude
DOCUMENT_RECOGNIZER_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# --- Google Calendar sync for driver vacations ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (Web application). Redirect URI: <host>/vacations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Which calendar to write vacations into: "primary" = the connected account's
# main calendar, or a specific calendar ID (…@group.calendar.google.com).
GOOGLE_CALENDAR_ID=primary
# Calendar embedded as the month view on the fleet Vacations page. Use the
# calendar's address (account email, or …@group.calendar.google.com) and make
# the calendar public/shared so the iframe renders for app users.
GOOGLE_CALENDAR_EMBED_ID=
GOOGLE_CALENDAR_TZ=Europe/Warsaw